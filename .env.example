# NextAuth.js configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Authentication credentials
# Set the username for the single admin user
AUTH_USERNAME=admin

# Generate bcrypt hash for your password (e.g., using: node -e "const b=require('bcryptjs');b.hash('your-password',10).then(console.log)")
AUTH_PASSWORD_HASH=$2a$10$...your-bcrypt-hash-here...

# Anthropic API key for LLM-powered transaction parsing (required for US-004+)
ANTHROPIC_API_KEY=sk-ant-...

# Database (required for US-002+)
DATABASE_URL=file:./prisma/dev.db
