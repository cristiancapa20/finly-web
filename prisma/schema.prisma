generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  displayName  String?
  avatar       String?
  createdAt    DateTime      @default(now())
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  loans        Loan[]
}

model Loan {
  id                  String        @id @default(cuid())
  type                String        // "LENT" | "OWED"
  contactName         String
  amount              Int           // total in cents
  description         String?
  dueDate             DateTime?
  status              String        @default("ACTIVE") // "ACTIVE" | "PAID"
  reminderDays        Int?          // notify X days before due date
  accountId           String?
  balanceTransactionId String?      @unique
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  account             Account?      @relation(fields: [accountId], references: [id])
  payments            LoanPayment[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model LoanPayment {
  id                   String   @id @default(cuid())
  loanId               String
  accountId            String?
  balanceTransactionId String?  @unique
  loan                 Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  account              Account? @relation(fields: [accountId], references: [id])
  amount               Int      // amount in cents
  date                 DateTime
  note                 String?
  createdAt            DateTime @default(now())
}

model Category {
  id           String        @id @default(cuid())
  name         String
  color        String
  icon         String?
  isSystem     Boolean       @default(false)
  userId       String?
  user         User?         @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Account {
  id           String        @id @default(cuid())
  name         String
  type         String
  color        String        @default("#1e3a5f")
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  loans        Loan[]
  loanPayments LoanPayment[]
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Int
  type        String
  categoryId  String
  accountId   String
  userId      String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  category    Category @relation(fields: [categoryId], references: [id])
  account     Account  @relation(fields: [accountId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}
